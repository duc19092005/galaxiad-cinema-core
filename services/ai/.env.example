# Environment: development | production
ENVIRONMENT=development

# Embedding backend: local | cloud
EMBEDDING_BACKEND=local

# Local Embedding Settings (BAAI/bge-m3 runs inside the container)
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIM=1024

# Cloud Embedding Settings (Jina AI - used when EMBEDDING_BACKEND=cloud)
JINA_API_KEY=your_jina_api_key_here

# Google Gemini API Key (for movie embedding generation, not for chat)
GOOGLE_API_KEY=your_google_api_key_here

# Server settings
HOST=0.0.0.0
PORT=8000

# Qdrant Vector DB Settings
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=cinema_movies

# DeepSeek LLM Settings (For chat, intent classification & safety guard filter)
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
